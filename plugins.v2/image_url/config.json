{
    "name": "图片URL插件",
    "description": "自动处理图片URL，支持图片上传和转换。",
    "version": "1.0.0",
    "author": "jinxi",
    "type": "url",
    "settings": {
        "enabled": false,
        "notify": false,
        "cron": "0 0 * * *",
        "onlyonce": false,
        "retry_count": 3,
        "retry_interval": 5,
        "image_host": "",
        "api_key": "",
        "url_processing": {
            "strip_whitespace": true,
            "validate_url": true,
            "timeout": 30
        },
        "logging": {
            "level": "info",
            "save_to_file": true
        }
    }
} 